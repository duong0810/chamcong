    }

    .already-registered-icon {
        font-size: 3.5rem;
        margin-bottom: 0.75rem;
    }

    .already-registered-box h5 {
        color: #155724;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .webcam-section {
        background-color: #f8f9fa;
        padding: 1rem;
        border-radius: 8px;
    }

        .webcam-section h5 {
            margin-bottom: 0.75rem;
            font-size: 0.95rem;
        }

    .camera-placeholder {
        background: #e9ecef;
        border: 1.5px dashed #b3b8bd;
        border-radius: 8px;
        padding: 2rem;
        text-align: center;
    }

    /* VIDEO wrapper - same as Attendance */
    .video-wrapper {
        position: relative;
        width: 100%;
        max-width: 780px;
        margin: 0 auto;
    }

    .video-container {
        position: relative;
        width: 100%;
        background: #000;
        border-radius: 8px;
        overflow: hidden;
        aspect-ratio: 4 / 3;
    }

    #webcam {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
    }

    .guide-ellipse.captured {
        animation: capture-flash 0.8s ease-in-out 1;
        stroke-width: 6 !important;
        opacity: 1 !important;
    }

    @@keyframes capture-flash {
        0% {
            transform: scale(1);
            opacity: 1;
            stroke: #28a745;
        }

        40% {
            transform: scale(1.12);
            opacity: 0.95;
            stroke: #ffffff;
        }

        100% {
            transform: scale(1);
            opacity: 1;
            stroke: #28a745;
        }
