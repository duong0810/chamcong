    private async Task PerformAttendanceAsync(bool isCheckIn)
    {
        if (!IsLivenessComplete()) // ✅ CẬP NHẬT
        {
            message = $"⚠️ Vui lòng hoàn thành xác thực khuôn mặt ({GetCompletionSteps()}) trước!";
            isSuccess = false;
            await StopCameraAsync();
            return;
        }

        isProcessing = true;
        processingAction = isCheckIn ? "checkin" : "checkout";
        message = "";
        recognizedEmployee = null;

        EmployeeDto? matchedEmployee = null;
        double bestMatchScore = 0;

        try
        {
            isRecognizing = true;
            StateHasChanged();

            FaceCaptureResult? capturedFace = null;

            if (lastCapturedFace != null)
            {
                capturedFace = lastCapturedFace;
                lastCapturedFace = null;
            }
            else
            {
                capturedFace = await JsInvokeWithTimeout(() => JS.InvokeAsync<FaceCaptureResult>("captureFaceDescriptor", "attendanceWebcam").AsTask(), 6000);

                if (capturedFace == null)
                {
                    Console.WriteLine("❌ captureFaceDescriptor returned null or timed out");
                    message = "⚠️ Không phát hiện khuôn mặt hoặc timeout. Vui lòng thử lại.";
                    isSuccess = false;
                    isRecognizing = false;

                    processingAction = null;
                    isProcessing = false;
                    capturedEffect = false;

                    await StopCameraAsync(preserveMessage: true);
                    return;
                }
            }

            if (capturedFace == null || capturedFace.Descriptor == null || capturedFace.Descriptor.Length != 128)
            {
                message = "⚠️ Không phát hiện khuôn mặt. Vui lòng thử lại.";
                isSuccess = false;
                isRecognizing = false;

                processingAction = null;
                isProcessing = false;
                capturedEffect = false;

                await StopCameraAsync(preserveMessage: true);
                return;
            }

            Console.WriteLine($"📸 Đã chụp khuôn mặt, detection score: {capturedFace.Score:F3}");

            if (capturedFace.Score < MinDetectionScore)
            {
                message = "⚠️ Ảnh chụp kém chất lượng (độ tin cậy thấp). Vui lòng thử lại trong điều kiện ánh sáng tốt hơn.";
                isSuccess = false;
                isRecognizing = false;
                processingAction = null;
                isProcessing = false;
                await StopCameraAsync(preserveMessage: true);
                return;
            }

            foreach (var emp in employees)
            {
                var storedDescriptor = await ApiService.GetFaceDescriptorAsync(emp.Id);
                if (storedDescriptor == null || storedDescriptor.Length != 128) continue;

                var comparison = await JS.InvokeAsync<FaceComparisonResult>(
                    "compareFaceDescriptors",
                    capturedFace.Descriptor,
                    storedDescriptor
                );

                Console.WriteLine($"🔍 So sánh với {emp.FullName}: Distance={comparison.Distance:F3}, Similarity={comparison.Similarity:F1}%");

                if (comparison.Similarity >= MinSimilarityPercent && comparison.Similarity > bestMatchScore)
                {
                    bestMatchScore = comparison.Similarity;
                    matchedEmployee = emp;
                }
            }

            isRecognizing = false;

            if (matchedEmployee == null)
            {
                message = "⚠️ Không nhận diện được khuôn mặt đáng tin cậy. Vui lòng đăng ký khuôn mặt trước (Trang: Đăng ký khuôn mặt).";
                isSuccess = false;

                await StopCameraAsync(preserveMessage: true);
                return;
            }

            recognizedEmployee = matchedEmployee;
            faceMatchScore = bestMatchScore / 100.0;

            Console.WriteLine($"✅ Nhận diện thành công: {matchedEmployee.FullName} (Score: {faceMatchScore:P1})");

            await InvokeAsync(StateHasChanged);

            string? imageDataUrl = null;
            try
            {
                imageDataUrl = await JsInvokeWithTimeout(() => JS.InvokeAsync<string?>("captureImageDataUrl", "attendanceWebcam", 640, 480).AsTask(), 5000);
                Console.WriteLine($"📷 Chụp ảnh: {(imageDataUrl != null ? "thành công" : "null/thất bại")}");
            }
            catch (Exception jsImgEx)
            {
                Console.WriteLine($"⚠️ Không thể chụp ảnh: {jsImgEx.Message}");
                imageDataUrl = null;
            }

            gpsLocation = await JsInvokeWithTimeout(() => JS.InvokeAsync<LocationDto>("getGeolocation").AsTask(), 5000);

            lastDistanceMeters = null;
            lastWithinThreshold = false;

            if (gpsLocation != null && companyCoordsAvailable)
            {
                lastDistanceMeters = HaversineDistanceMeters(gpsLocation.Latitude, gpsLocation.Longitude, CompanyLat.Value, CompanyLng.Value);
                lastWithinThreshold = lastDistanceMeters <= LocationAcceptThresholdMeters;
            }
            else if (gpsLocation != null && !companyCoordsAvailable && !string.IsNullOrWhiteSpace(CompanyLocationUrl))
            {
                if (TryParseGoogleMapsUrl(CompanyLocationUrl, out var latC, out var lngC))
                {
                    CompanyLat = latC;
                    CompanyLng = lngC;
                    lastDistanceMeters = HaversineDistanceMeters(gpsLocation.Latitude, gpsLocation.Longitude, CompanyLat.Value, CompanyLng.Value);
                    lastWithinThreshold = lastDistanceMeters <= LocationAcceptThresholdMeters;
                }
            }

            string? deviceInfo = null;
            string? clientIp = null;

            try
            {
                deviceInfo = await JS.InvokeAsync<string>("getDeviceInfo");
                Console.WriteLine($"📱 Device Info: {deviceInfo}");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"⚠️ Không lấy được device info: {ex.Message}");
                deviceInfo = "Unknown Device";
            }

            try
            {
                clientIp = await JS.InvokeAsync<string>("getPublicIP");
                Console.WriteLine($"🌐 Client IP: {clientIp}");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"⚠️ Không lấy được IP: {ex.Message}");
                clientIp = "Unknown";
            }

            var dto = new AttendanceDto
            {
                EmployeeId = matchedEmployee.Id,
                CheckInTime = isCheckIn ? DateTime.Now : default,
                CheckOutTime = isCheckIn ? null : DateTime.Now,
                Location = "Văn phòng KOSMOS DEVELOPMENT",
                Latitude = gpsLocation?.Latitude,
                Longitude = gpsLocation?.Longitude,
                Accuracy = gpsLocation?.Accuracy,
                FaceMatchScore = faceMatchScore,
                IsManualEntry = false,
                CheckInDistanceMeters = isCheckIn ? lastDistanceMeters : null,
                CheckOutDistanceMeters = !isCheckIn ? lastDistanceMeters : null,
                CheckInFaceImageBase64 = isCheckIn ? imageDataUrl : null,
                CheckOutFaceImageBase64 = !isCheckIn ? imageDataUrl : null,

                CheckInIp = isCheckIn ? clientIp : null,
                CheckOutIp = !isCheckIn ? clientIp : null,
                CheckInDeviceInfo = isCheckIn ? deviceInfo : null,
                CheckOutDeviceInfo = !isCheckIn ? deviceInfo : null


            };

            var result = isCheckIn
                ? await ApiService.CheckInAsync(dto)
                : await ApiService.CheckOutAsync(dto);

            Console.WriteLine($"🔁 API result: Success={(result?.Success ?? false)}, Message='{result?.Message ?? "<null>"}'");

            if (result != null && result.Success)
            {
                var baseMsg = string.IsNullOrWhiteSpace(result.Message)
                              ? (isCheckIn ? "Chấm công VÀO thành công" : "Chấm công RA thành công")
                              : result.Message;

                if (recognizedEmployee != null && !string.IsNullOrWhiteSpace(recognizedEmployee.FullName))
                {
                    if (!baseMsg.Contains(recognizedEmployee.FullName, StringComparison.OrdinalIgnoreCase))
                    {
                        baseMsg = $"{baseMsg} — {recognizedEmployee.FullName}";
                    }
                }

                if (lastDistanceMeters.HasValue)
                {
                    message = $"{baseMsg} Khoảng cách tới công ty: {lastDistanceMeters.Value:F1} m. {(lastWithinThreshold ? "Trong phạm vi" : "Ngoài phạm vi")}.";
                }
                else if (gpsLocation == null)
                {
                    message = $"{baseMsg} (Không có GPS)";
                }
                else if (!companyCoordsAvailable)
                {
                    message = $"{baseMsg} (Vị trí công ty chưa cấu hình)";
                }
                else
                {
                    message = baseMsg;
                }

                isSuccess = true;
                await LoadTodayRecordsAsync();
            }
            else
            {
                message = result?.Message ?? (isCheckIn ? "Chấm công VÀO thất bại" : "Chấm công RA thất bại");
                isSuccess = false;
            }
        }
        catch (Exception ex)
        {
            message = $"Lỗi: {ex.Message}";
            isSuccess = false;
            isRecognizing = false;
            Console.WriteLine($"❌ Lỗi chấm công: {ex.Message}");
        }
        finally
        {
            processingAction = null;
            isProcessing = false;

            try
            {
                await StopCameraAsync(preserveMessage: true);
            }
            catch { }
        }
    }

    private static double HaversineDistanceMeters(double lat1, double lon1, double lat2, double lon2)
    {
        double R = 6371000;
        double toRad = Math.PI / 180.0;
        var dLat = (lat2 - lat1) * toRad;
        var dLon = (lon2 - lon1) * toRad;
        var a = Math.Sin(dLat / 2) * Math.Sin(dLat / 2) +
                Math.Cos(lat1 * toRad) * Math.Cos(lat2 * toRad) *
                Math.Sin(dLon / 2) * Math.Sin(dLon / 2);
        var c = 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a));
        return R * c;
    }

    private static bool TryParseGoogleMapsUrl(string url, out double lat, out double lng)
    {
        lat = 0; lng = 0;
        try
        {
            if (string.IsNullOrWhiteSpace(url)) return false;
            var rx3d4d = new System.Text.RegularExpressions.Regex(@"!3d(-?\d+\.\d+)!4d(-?\d+\.\d+)");
            var m34 = rx3d4d.Match(url);
            if (m34.Success)
            {
                if (double.TryParse(m34.Groups[1].Value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out lat) &&
                    double.TryParse(m34.Groups[2].Value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out lng))
                    return true;
            }

            var atIndex = url.IndexOf("/@");
            if (atIndex >= 0)
            {
                var seg = url.Substring(atIndex + 2);
                var parts = seg.Split(',');
                if (parts.Length >= 2 &&
                    double.TryParse(parts[0], System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out lat) &&
                    double.TryParse(parts[1], System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out lng))
                {
                    return true;
                }
            }

            var placeIndex = url.IndexOf("/place/");
            if (placeIndex >= 0)
            {
                var seg = url.Substring(placeIndex + 7);
                var parts = seg.Split(new[] { '/', '?', '&' }, StringSplitOptions.RemoveEmptyEntries);
                if (parts.Length > 0)
                {
                    var first = parts[0];
                    var coords = first.Split(',');
                    if (coords.Length >= 2 &&
                        double.TryParse(coords[0], System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out lat) &&
                        double.TryParse(coords[1], System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out lng))
                    {
                        return true;
                    }
                }
            }

            if (Uri.TryCreate(url, UriKind.Absolute, out var uri))
            {
                var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
                var q = query.Get("q");
                if (!string.IsNullOrEmpty(q))
                {
                    var coords = q.Split(',');
                    if (coords.Length >= 2 &&
                        double.TryParse(coords[0], System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out lat) &&
                        double.TryParse(coords[1], System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out lng))
                    {
                        return true;
                    }
                }
            }

            var rx = new System.Text.RegularExpressions.Regex(@"(-?\d+\.\d+),\s*(-?\d+\.\d+)");
            var matches = rx.Matches(url);
            if (matches.Count > 0)
            {
                var m = matches[matches.Count - 1];
                if (double.TryParse(m.Groups[1].Value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out lat) &&
                    double.TryParse(m.Groups[2].Value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out lng))
                {
                    return true;
                }
            }
        }
        catch { }
        return false;
    }

