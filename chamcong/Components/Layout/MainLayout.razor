@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <div class="top-row ps-3 navbar navbar-dark">
            <div class="container-fluid">
                <a class="navbar-brand" href="">📱 Chấm Công</a>
            </div>
        </div>

        <input type="checkbox" title="Navigation menu" class="navbar-toggler" />

        <div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
            <nav class="flex-column">
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <span class="bi bi-house-door" aria-hidden="true"></span> Trang chủ
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="attendance">
                        <span class="bi bi-camera" aria-hidden="true"></span> Chấm công
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="history">
                        <span class="bi bi-list" aria-hidden="true"></span> Lịch sử
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="employees">
                        <span class="bi bi-people" aria-hidden="true"></span> Nhân viên
                    </NavLink>
                </div>

                <!-- ADMIN: Company Settings -->
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/company-settings">
                        <span class="bi bi-gear" aria-hidden="true"></span> Cài đặt
                    </NavLink>
                </div>
            </nav>
        </div>
    </div>

    <main>
        <div class="top-row px-4">
            <h3>⏰ Hệ Thống Chấm Công</h3>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<style>
    .page {
        position: relative;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    .sidebar {
        background-image: linear-gradient(180deg, rgb(5, 39, 103) 0%, #3a0647 70%);
    }

    /* Main top-row (keeps light header in main area) */
    .top-row {
        background-color: #f7f7f7;
        border-bottom: 1px solid #d6d5d5;
        justify-content: space-between;
        height: 2.4rem; /* further reduced */
        display: flex;
        align-items: center;
    }

        .top-row h3 {
            margin: 0;
            font-size: 1rem; /* slightly smaller */
            color: #512bd4;
        }

    /* Sidebar-specific top-row: make transparent so gradient shows through and ensure contrast */
    .sidebar .top-row {
        background: transparent;
        border-bottom: none;
        justify-content: flex-start;
        padding-left: 0.4rem;
        height: 2.4rem; /* match reduced height */
        display: flex;
        align-items: center;
    }

    main {
        flex: 1;
    }

    .content {
        padding: 0.75rem !important; /* tighter content padding */
    }

    .navbar-toggler {
        appearance: none;
        cursor: pointer;
        width: 2.6rem; /* smaller */
        height: 2rem;
        color: white;
        position: absolute;
        top: 0.35rem;
        right: 0.9rem;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba%28255, 255, 255, 0.55%29' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e") no-repeat center/1.4rem;
    }

        .navbar-toggler:checked ~ .nav-scrollable {
            display: block;
        }

    /* Default brand style (fallback) */
    .navbar-brand {
        font-size: 0.95rem; /* slightly smaller */
        font-weight: 700;
        color: darkred;
        opacity: 1;
    }

    /* Sidebar brand override for good contrast on gradient */
    .sidebar .navbar-brand {
        color: #ffffff !important;
        font-weight: 700;
        font-size: 0.95rem; /* reduced */
        text-shadow: 0 1px 2px rgba(0,0,0,0.55);
        opacity: 1;
        filter: none;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        padding-left: 0.25rem;
    }

    .nav-item {
        font-size: 0.85rem; /* smaller */
        padding-bottom: 0.35rem;
    }

        .nav-item:first-of-type {
            padding-top: 0.6rem;
        }

        .nav-item:last-of-type {
            padding-bottom: 0.6rem;
        }

    .nav-link {
        color: #d7d7d7;
        border-radius: 6px;
        height: 2.2rem; /* reduced for compact look */
        display: flex;
        align-items: center;
        line-height: 1;
        padding: 0 0.5rem;
        font-weight: 600;
    }

        .nav-link:hover {
            background-color: rgba(255,255,255,0.06);
            color: white;
        }

        .nav-link.active {
            background-color: rgba(255,255,255,0.22);
            color: white;
        }

    .bi {
        width: 1.4rem; /* smaller icon */
        height: 1.4rem;
        display: inline-block;
        margin-right: 0.5rem;
        flex: 0 0 1.4rem;
    }

    @@media (min-width: 641px) {
        .page {
            flex-direction: row;
        }

        .sidebar {
            width: 200px; /* reduced to 200px */
            height: 100vh;
            position: sticky;
            top: 0;
        }

        .navbar-toggler {
            display: none;
        }

        .nav-scrollable {
            display: block;
            overflow-y: auto;
            padding-right: 0.2rem;
        }

        .top-row {
            position: sticky;
            top: 0;
            z-index: 1;
        }
    }
</style>