    private async Task<T?> JsInvokeWithTimeout<T>(Func<Task<T>> jsCall, int timeoutMs = 5000)
    {
        try
        {
            var jsTask = jsCall();
            var delay = Task.Delay(timeoutMs);
            var completed = await Task.WhenAny(jsTask, delay);
            if (completed != jsTask)
            {
                Console.WriteLine($"❌ JS call timeout after {timeoutMs}ms");
                return default;
            }
            return await jsTask;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ JsInvokeWithTimeout error: {ex.Message}");
            return default;
        }
    }

    private async Task StartAutoCaptureAfterDelayAsync()
    {
        _autoCaptureCts?.Cancel();
        _autoCaptureCts = new CancellationTokenSource();
        var token = _autoCaptureCts.Token;

        try
        {
            await Task.Delay(2000, token);
            if (token.IsCancellationRequested) return;
            if (!IsLivenessComplete()) return; // ✅ CẬP NHẬT
            if (isAutoCapturing) return;

            isAutoCapturing = true;
            await InvokeAsync(() =>
            {
                isRecognizing = true;
                capturedEffect = true;
                StateHasChanged();
            });

            await Task.Delay(300, token);

            FaceCaptureResult? capturedFace = null;

            if (lastCapturedFace != null)
            {
                capturedFace = lastCapturedFace;
                lastCapturedFace = null;
            }
            else
            {
                capturedFace = await JsInvokeWithTimeout(() => JS.InvokeAsync<FaceCaptureResult>("captureFaceDescriptor", "attendanceWebcam").AsTask(), 6000);
                if (capturedFace == null)
                {
                    await InvokeAsync(() =>
                    {
                        message = "⚠️ Không phát hiện khuôn mặt. Vui lòng đưa mặt lại gần camera.";
                        isSuccess = false;
                        isRecognizing = false;
                        StateHasChanged();
                    });

                    await StopCameraAsync(preserveMessage: true);
                    return;
                }
            }

            if (capturedFace == null || capturedFace.Descriptor == null || capturedFace.Descriptor.Length != 128)
            {
                await InvokeAsync(() =>
                {
                    message = "⚠️ Không phát hiện khuôn mặt. Vui lòng đưa mặt lại gần camera.";
                    isSuccess = false;
                    isRecognizing = false;
                    StateHasChanged();
                });

                await StopCameraAsync(preserveMessage: true);
                return;
            }

            Console.WriteLine($"📸 Auto-capture detection score: {capturedFace.Score:F3}");

            if (capturedFace.Score < MinDetectionScore)
            {
                await InvokeAsync(() =>
                {
                    message = "⚠️ Ảnh chụp kém chất lượng. Vui lòng thử lại.";
                    isSuccess = false;
                    isRecognizing = false;
                    StateHasChanged();
                });
                await StopCameraAsync(preserveMessage: true);
                return;
            }

            lastCapturedFace = capturedFace;

            EmployeeDto? matchedEmployee = null;
            double bestMatchScore = 0;

            foreach (var emp in employees)
            {
                var storedDescriptor = await ApiService.GetFaceDescriptorAsync(emp.Id);
                if (storedDescriptor == null || storedDescriptor.Length != 128)
                {
                    continue;
                }

                var comparison = await JS.InvokeAsync<FaceComparisonResult>(
                    "compareFaceDescriptors",
                    capturedFace.Descriptor,
                    storedDescriptor
                );

                if (comparison.Similarity >= MinSimilarityPercent && comparison.Similarity > bestMatchScore)
                {
                    bestMatchScore = comparison.Similarity;
                    matchedEmployee = emp;
                }
            }

            isRecognizing = false;
            isAutoCapturing = false;

            if (matchedEmployee == null)
            {
                await InvokeAsync(() =>
                {
                    message = "⚠️ Không nhận diện được khuôn mặt. Vui lòng đăng kí khuôn mặt hoặc thử lại !";
                    isSuccess = false;
                    StateHasChanged();
                });

                await StopCameraAsync(preserveMessage: true);
                return;
            }

            recognizedEmployee = matchedEmployee;
            faceMatchScore = bestMatchScore / 100.0;

            await InvokeAsync(() =>
            {
                message = $"✅ Tự nhận diện: {recognizedEmployee.FullName} (Độ khớp: {faceMatchScore:P1}).";
                isSuccess = true;
                StateHasChanged();
            });

            if (!string.IsNullOrEmpty(pendingAttendanceAction))
            {
                var action = pendingAttendanceAction;
                pendingAttendanceAction = null;
                await InvokeAsync(async () => await PerformAttendanceAsync(action == "checkin"));
            }
            else
            {
                await InvokeAsync(() =>
                {
                    message = $"✅ Tự nhận diện: {recognizedEmployee.FullName} (Độ khớp: {faceMatchScore:P1}). Vui lòng bấm Chấm công.";
                    isSuccess = true;
                    StateHasChanged();
                });
            }
        }
        catch (TaskCanceledException) { }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ StartAutoCaptureAfterDelayAsync error: {ex.Message}");
        }
        finally
        {
            try
            {
                isRecognizing = false;
                isAutoCapturing = false;
                await InvokeAsync(StateHasChanged);
            }
            catch { }
        }
    }

