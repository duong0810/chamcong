@code {
    // ===== CHUNG =====
    private string activeTab = "attendance";
    private bool canViewLoginHistory = false;
    private bool canManualEdit = false;

    // ===== TAB CHẤM CÔNG =====
    private List<EmployeeDto> employees = new();
    private List<AttendanceHistoryDto> records = new();
    private int selectedEmployeeId = 0;
    private int days = 30;
    private bool isLoadingAttendance = false;

    // Alert sửa giờ
    private string editMessage = "";
    private bool editSuccess = false;

    // Modal ảnh
    private bool isImageModalOpen = false;
    private string? modalImageUrl;

    // ===== MODAL SỬA GIỜ =====
    private bool showEditModal = false;
    private bool isSaving = false;
    private AttendanceHistoryDto? editingRecord;
    private DateTime editNewCheckIn;
    private DateTime? editNewCheckOut;
    private string editReason = "";

    // ===== MODAL LOG SỬA =====
    private bool showLogModal = false;
    private bool isLoadingLogs = false;
    private List<AttendanceEditLogDto> editLogs = new();

    // ===== TAB ĐĂNG NHẬP =====
    private List<LoginLogDto> loginLogs = new();
    private int loginDays = 30;
    private string loginSearch = "";
    private string loginRoleFilter = "";
    private bool isLoadingLogin = false;

    private IEnumerable<LoginLogDto> FilteredLoginLogs => loginLogs
        .Where(l =>
            (string.IsNullOrEmpty(loginSearch) ||
             l.Username.Contains(loginSearch, StringComparison.OrdinalIgnoreCase) ||
             l.FullName.Contains(loginSearch, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(loginRoleFilter) || l.Role == loginRoleFilter));

    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var tabParam = query["tab"];
        if (!string.IsNullOrEmpty(tabParam))
            activeTab = tabParam;

        employees = await ApiService.GetEmployeesAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthService.TryRestoreSessionAsync();
            canViewLoginHistory = await AuthService.HasPermissionAsync("Users.Manage");

            // Chỉ Admin và Manager mới được sửa giờ chấm công
            var isUserRole = await AuthService.HasRoleAsync("User");
            canManualEdit = !isUserRole;

            if (activeTab == "login" && !canViewLoginHistory)
                activeTab = "attendance";

            if (activeTab == "login" && canViewLoginHistory && !loginLogs.Any())
                await LoadLoginHistoryAsync();

            StateHasChanged();
        }
    }

    private async Task SwitchTab(string tab)
    {
        activeTab = tab;
        Navigation.NavigateTo($"/history?tab={tab}", forceLoad: false);
        if (tab == "login" && !loginLogs.Any())
            await LoadLoginHistoryAsync();
    }

    private async Task LoadHistoryAsync()
    {
        if (selectedEmployeeId == 0) return;
        isLoadingAttendance = true;
        try { records = await ApiService.GetHistoryAsync(selectedEmployeeId, days); }
        finally { isLoadingAttendance = false; }
    }

    private async Task LoadLoginHistoryAsync()
    {
        isLoadingLogin = true;
        loginLogs = await ApiService.GetLoginHistoryAsync(loginDays);
        isLoadingLogin = false;
    }

    // ===== SỬA GIỜ CHẤM CÔNG =====
    private void OpenEditModal(AttendanceHistoryDto record)
    {
        editingRecord = record;
        editNewCheckIn = record.CheckInTime;
        editNewCheckOut = record.CheckOutTime;
        editReason = "";
        showEditModal = true;
    }

    private void CloseEditModal()
    {
        if (!isSaving) showEditModal = false;
    }

    private async Task SaveManualEdit()
    {
        if (editingRecord == null) return;

        if (string.IsNullOrWhiteSpace(editReason))
        {
            editMessage = "Vui lòng nhập lý do sửa!";
            editSuccess = false;
            return;
        }

        if (editNewCheckOut.HasValue && editNewCheckOut.Value <= editNewCheckIn)
        {
            editMessage = "Giờ ra phải sau giờ vào!";
            editSuccess = false;
            return;
        }

        isSaving = true;
        try
        {
            var userDto = await AuthService.GetCurrentUserAsync();
            var dto = new ManualEditDto
            {
                NewCheckInTime = editNewCheckIn,
                NewCheckOutTime = editNewCheckOut,
                Reason = editReason,
                EditedByUserId = userDto?.Id ?? 0,
                EditedByUsername = userDto?.Username ?? "unknown"
            };

            var (success, message) = await ApiService.ManualEditAttendanceAsync(editingRecord.Id, dto);
            editMessage = message;
            editSuccess = success;

            if (success)
            {
                showEditModal = false;
                await LoadHistoryAsync(); // Reload bảng
            }
        }
        finally { isSaving = false; }
    }

    // ===== XEM LOG SỬA =====
    private async Task OpenLogModal(AttendanceHistoryDto record)
    {
        editingRecord = record;
        showLogModal = true;
        isLoadingLogs = true;
        editLogs = new();
        StateHasChanged();

        editLogs = await ApiService.GetAttendanceEditLogsAsync(record.Id);
        isLoadingLogs = false;
    }

    private void CloseLogModal() => showLogModal = false;

    // ===== ẢNH =====
    private void OpenImageModal(string url) { modalImageUrl = url; isImageModalOpen = true; }
    private void CloseImageModal() { isImageModalOpen = false; modalImageUrl = null; }

    private string GetRoleLabel(string role) => role switch
    {
        "Admin" => "👑 Admin",
        "Manager" => "🎯 Manager",
        _ => "👤 User"
    };

    private string TruncateUserAgent(string ua)
    {
        if (string.IsNullOrEmpty(ua)) return "-";
        if (ua.Contains("Chrome")) return "Chrome";
        if (ua.Contains("Firefox")) return "Firefox";
        if (ua.Contains("Safari")) return "Safari";
        if (ua.Contains("Edge")) return "Edge";
        return ua.Length > 30 ? ua[..30] + "..." : ua;
    }
}