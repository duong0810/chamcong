    .camera-controls {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .alert-info ol {
        padding-left: 1.2rem;
    }

    .alert-info li {
        margin-bottom: 0.5rem;
    }

    /* Overlay: same placement & behavior as Attendance */
    .face-guide-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        pointer-events: none;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .face-guide-frame {
        width: clamp(260px, 70%, 460px);
        max-width: 94%;
        max-height: 94%;
        height: auto;
        box-sizing: border-box;
        opacity: 0.96;
        display: block;
        transition: width 160ms ease, opacity 160ms ease, transform 160ms ease;
    }

        .face-guide-frame .guide-ellipse {
            stroke: rgba(255,255,255,0.98);
            stroke-width: 7;
            stroke-dasharray: 14 9;
            stroke-linecap: round;
            filter: drop-shadow(0 3px 8px rgba(0,0,0,0.55));
            transition: stroke 200ms ease, stroke-width 140ms ease, stroke-dasharray 200ms ease, filter 200ms ease;
        }

            .face-guide-frame .guide-ellipse.liveness-step-5,
            .face-guide-frame .liveness-step-5.guide-ellipse {
                stroke: #28a745;
                stroke-dasharray: 8 4;
                stroke-width: 7;
                filter: drop-shadow(0 4px 10px rgba(40,167,69,0.45));
            }

        .face-guide-frame svg,
        .face-guide-frame {
            display: block;
        }

    .liveness-progress {
        position: absolute;
        top: 8%;
        left: 50%;
        transform: translateX(-50%);
        width: 86%;
        max-width: 640px;
        z-index: 1010;
    }

    .face-guide-text {
        position: absolute;
        bottom: 6%;
        left: 50%;
        transform: translateX(-50%);
        z-index: 1025;
        color: #fff;
        text-align: center;
        padding: 4px 8px;
        background: rgba(0,0,0,0.45);
        border-radius: 6px;
        font-weight: 500;
        font-size: 0.88rem;
        line-height: 1.1;
        max-width: 86%;
        box-sizing: border-box;
        transition: bottom 160ms ease, opacity 140ms ease;
    }

    .face-status-icon {
        position: absolute;
        top: 6%;
        right: 6%;
        z-index: 1015;
        font-size: 1.1rem;
    }

    @@media (max-width: 640px) {
        .face-guide-text {
            bottom: 8px;
            font-size: 0.78rem;
            padding: 3px 8px;
            max-width: 92%;
        }

        .register-face-container {
            padding: 0 0.5rem;
        }

        .page-title {
            font-size: 1.4rem;
            margin-bottom: 0.9rem;
        }

        .webcam-section {
            padding: 0.9rem;
        }

        .camera-placeholder {
            padding: 1.6rem;
        }

        .face-guide-frame {
            width: clamp(160px, 74%, 300px);
            max-width: 90%;
            max-height: 86%;
        }

            .face-guide-frame svg {
                width: 100%;
                height: auto;
            }

            .face-guide-frame .guide-ellipse {
                stroke-width: 6;
                stroke-dasharray: 12 10;
            }
    }
</style>

@code {
    private bool isModelsLoading = false;
    private bool isModelsReady = false;

    private EmployeeDto? currentEmployee = null;
    private bool alreadyRegistered = false;
    private bool isLoading = true;
    private bool isUserRole = false;

    private int selectedEmployeeId = 0;
    private bool isCameraStarted = false;
    private bool isProcessing = false;
    private string message = "";
    private bool isSuccess = false;

    private int livenessStep = 0;
    private string livenessMessage = "Nhấn 'Bật Camera' để bắt đầu";

    private DotNetObjectReference<RegisterFace>? dotNetRef;
    private bool _isDisposed = false;

    private bool isAutoCapturing = false;
    private CancellationTokenSource? _autoCaptureCts;
    private FaceCaptureResult? lastCapturedFace = null;
    private bool capturedEffect = false;

    private bool _startWebcamAfterRender = false;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthService.TryRestoreSessionAsync(); // ✅ Restore session trước
            await LoadCurrentEmployeeAsync();
            _ = PreloadFaceModelsAsync();
            await InvokeAsync(StateHasChanged);
        }

        if (_startWebcamAfterRender)
        {
            _startWebcamAfterRender = false;
            try
            {
                await JS.InvokeVoidAsync("startWebcam", "webcam");
                message = "✅ Camera đã sẵn sàng! Hoàn thành 5 bước xác thực để đăng ký";
                isSuccess = true;
                await StartLivenessDetectionAsync();
            }
            catch (Exception ex)
            {
                message = $"❌ Lỗi bật camera: {ex.Message}";
                isSuccess = false;
                isCameraStarted = false;
            }
            finally
            {
                isProcessing = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task PreloadFaceModelsAsync()
    {
        try
        {
            isModelsLoading = true;
            isModelsReady = false;
            await InvokeAsync(StateHasChanged);

            var result = await JS.InvokeAsync<bool>("loadFaceModels");
            isModelsReady = result;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"⚠️ Preload face models failed: {ex.Message}");
            isModelsReady = false;
        }
        finally
        {
            isModelsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
        if (isModelsReady)
        {
            await Task.Delay(5000);
            isModelsReady = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadCurrentEmployeeAsync()
    {
        isLoading = true;
        try
        {
            var user = await AuthService.GetCurrentUserAsync();
            if (user == null) return;

            // ✅ Kiểm tra role
            isUserRole = await AuthService.HasRoleAsync("User");

            var employees = await ApiService.GetEmployeesAsync();

            // ✅ Ưu tiên tìm theo EmployeeId (chính xác), fallback sang FullName
            if (user.EmployeeId.HasValue && user.EmployeeId.Value > 0)
            {
                currentEmployee = employees.FirstOrDefault(e => e.Id == user.EmployeeId.Value);
            }
            else
            {
                currentEmployee = employees.FirstOrDefault(e =>
                    string.Equals(e.FullName, user.FullName, StringComparison.OrdinalIgnoreCase));
            }

            if (currentEmployee != null)
            {
                selectedEmployeeId = currentEmployee.Id;
                alreadyRegistered = currentEmployee.HasFace;

                // ✅ Chặn User đã có face: hiển thị thông báo rồi redirect
                if (isUserRole && alreadyRegistered)
                {
                    isLoading = false;
                    message = "✅ Khuôn mặt của bạn đã được đăng ký trong hệ thống.";
                    isSuccess = true;
                    await InvokeAsync(StateHasChanged);
                    await Task.Delay(4000);
                    Navigation.NavigateTo("/home", replace: true);
                    return;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Lỗi tải thông tin nhân viên: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AllowReRegister()
    {
        alreadyRegistered = false;
        message = "";
    }

    private async Task StartCameraAsync()
    {
        try
        {
            isProcessing = true;
            message = "";

            var hasPermission = await CheckCameraPermission();
            if (!hasPermission)
            {
                isProcessing = false;
                return;
            }

            isCameraStarted = true;
            _startWebcamAfterRender = true;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            message = $"❌ Lỗi bật camera: {ex.Message}";
            isSuccess = false;
            isCameraStarted = false;
            isProcessing = false;
            Console.WriteLine($"❌ Lỗi bật camera: {ex.Message}");
        }
    }

    

    private async Task StopCameraAsync()
    {
        try
        {
            try { _autoCaptureCts?.Cancel(); } catch { }
            await StopLivenessDetectionAsync();

            try
            {
                await JS.InvokeVoidAsync("stopWebcam", "webcam");
            }
            catch
            {
                try { await JS.InvokeVoidAsync("stopWebcam"); } catch { }
            }

            isCameraStarted = false;
            Console.WriteLine("✅ Camera đã tắt");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Lỗi tắt camera: {ex.Message}");
        }
    }

    private async Task StartLivenessDetectionAsync()
    {
        try
        {
            livenessStep = 0;
            livenessMessage = "Chuẩn bị...";

            try { dotNetRef?.Dispose(); } catch { }
            dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("startLivenessDetectionRegister", "webcam", DotNetObjectReference.Create(this));

            Console.WriteLine("✅ Đã bắt đầu Liveness Detection");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Lỗi bắt đầu liveness detection: {ex.Message}");
            message = "Lỗi khởi động liveness detection";
            isSuccess = false;
        }
    }

    private async Task StopLivenessDetectionAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("stopLivenessDetection");
            livenessStep = 0;
            livenessMessage = "Nhấn 'Bật Camera' để bắt đầu";

            Console.WriteLine("✅ Đã dừng Liveness Detection");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Lỗi dừng liveness detection: {ex.Message}");
        }
        finally
        {
            try { dotNetRef?.Dispose(); } catch { }
            dotNetRef = null;

            try { _autoCaptureCts?.Cancel(); } catch { }
            _autoCaptureCts = null;
            isAutoCapturing = false;
            capturedEffect = false;
        }
    }

    [JSInvokable]
    public void UpdateLivenessStep(int step, string message)
    {
        livenessStep = step;
        livenessMessage = message;
        StateHasChanged();

        Console.WriteLine($"📍 Liveness Step {step}: {message}");

        if (step == 5)
        {
            try { _autoCaptureCts?.Cancel(); } catch { }
            _ = StartAutoCaptureAfterDelayAsync();
        }
        else
        {
            try { _autoCaptureCts?.Cancel(); } catch { }
        }
    }

    private string GetLivenessClass()
    {
        string cls;
        if (livenessStep == 0) cls = "status-idle";
        else if (livenessStep == 5) cls = "liveness-step-5";
        else cls = $"liveness-step-{livenessStep}";

        if (capturedEffect) cls += " captured";

        return cls;
    }

    private int GetProgressPercentage() => livenessStep * 20;
    private string GetProgressBarClass() => livenessStep == 5 ? "bg-success" : "bg-warning";

    // private async Task<bool> CheckCameraPermission()
    // {
    //     try
    //     {
    //         var status = await JS.InvokeAsync<PermissionStatus>("checkPermissionsStatus");

    //         if (status.Camera == "denied")
    //         {
    //             message = "⚠️ Bạn đã từ chối quyền Camera. Vui lòng vào Cài đặt để bật lại.";
    //             isSuccess = false;
    //             var instructions = await JS.InvokeAsync<string>("showPermissionInstructions", "camera");
    //             Console.WriteLine(instructions);
    //             return false;
