    }

    .modal-backdrop-custom {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 1040;
    }

    .modal-custom {
        position: fixed;
        inset: 0;
        z-index: 1050;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .modal-custom-dialog {
        background: white;
        border-radius: 12px;
        width: 100%;
        max-width: 620px;
        max-height: 90vh;
