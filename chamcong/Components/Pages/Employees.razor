@code {
    private List<EmployeeDto> employees = new();
    private List<EmployeeDto> inactiveEmployees = new();
    private HashSet<int> pendingDeactivate = new(); // tracking checkbox đang được tích
    private bool isLoading = true;
    private bool isSaving = false;
    private string message = "";
    private bool isSuccess = false;
    private string searchText = "";
    private string activeTab = "active";

    private List<DepartmentDto> departments = new();
    private bool showAddDeptModal = false;
    private string newDepartmentName = "";
    private string deptErrorMessage = "";

    // Form modal
    private bool showFormModal = false;
    private bool isEditing = false;
    private EmployeeDto formModel = new();
    private Dictionary<string, string> errors = new();

    // Deactivate modal (nghỉ việc)
    private bool showDeactivateModal = false;
    private EmployeeDto? employeeToDeactivate = null;

    // Restore modal
    private bool showRestoreModal = false;
    private EmployeeDto? employeeToRestore = null;

    private bool canEdit = false;
    private bool canView = false;

    private IEnumerable<EmployeeDto> FilteredEmployees =>
        string.IsNullOrWhiteSpace(searchText) ? employees
        : employees.Where(e =>
            (e.FullName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (e.EmployeeCode?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (e.Department?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (e.Email?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false));

    private IEnumerable<EmployeeDto> FilteredInactiveEmployees =>
        string.IsNullOrWhiteSpace(searchText) ? inactiveEmployees
        : inactiveEmployees.Where(e =>
            (e.FullName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (e.EmployeeCode?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (e.Department?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (e.Email?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // ✅ Restore session trước khi check permission
            await AuthService.TryRestoreSessionAsync();

            canView = await AuthService.HasPermissionAsync("Employees.View");
            canEdit = await AuthService.HasPermissionAsync("Employees.Edit");

            if (!canView)
            {
                Navigation.NavigateTo("/");
                return;
            }
            await LoadEmployeesAsync();
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadEmployeesAsync();
        departments = await ApiService.GetDepartmentsAsync();
    }

    private async Task LoadEmployeesAsync()
    {
        isLoading = true;
        employees = await ApiService.GetEmployeesAsync();
        inactiveEmployees = await ApiService.GetInactiveEmployeesAsync();
        isLoading = false;
    }

    private async Task SwitchTab(string tab)
    {
        activeTab = tab;
        searchText = "";
        pendingDeactivate.Clear();
        await LoadEmployeesAsync();
    }

    // ===== CHECKBOX NGHỈ VIỆC =====
    private void ToggleDeactivate(EmployeeDto emp)
    {
        // Khi tích checkbox → hiện modal xác nhận
        employeeToDeactivate = emp;
        showDeactivateModal = true;
    }

    private void CloseDeactivateModal()
    {
        // Bỏ tích nếu hủy
        if (employeeToDeactivate != null)
            pendingDeactivate.Remove(employeeToDeactivate.Id);
        showDeactivateModal = false;
        employeeToDeactivate = null;
    }

    private async Task ConfirmDeactivate()
    {
        if (employeeToDeactivate == null) return;
        isSaving = true;
        try
        {
            var ok = await ApiService.DeleteEmployeeAsync(employeeToDeactivate.Id);
            if (ok)
            {
                message = $"✅ Đã cho nghỉ việc nhân viên {employeeToDeactivate.FullName}";
                isSuccess = true;
                showDeactivateModal = false;
                pendingDeactivate.Remove(employeeToDeactivate.Id);
                employeeToDeactivate = null;
                await LoadEmployeesAsync();
            }
            else
            {
                message = "❌ Thao tác thất bại. Vui lòng thử lại.";
                isSuccess = false;
                CloseDeactivateModal();
            }
        }
        finally { isSaving = false; }
    }

    // ===== THÊM =====
    private void OpenAddModal()
    {
        formModel = new EmployeeDto();
        isEditing = false;
        errors.Clear();
        showFormModal = true;
    }

    // ===== SỬA =====
    private void OpenEditModal(EmployeeDto emp)
    {
        formModel = new EmployeeDto
        {
            Id = emp.Id,
            EmployeeCode = emp.EmployeeCode,
            FullName = emp.FullName,
            Email = emp.Email,
            PhoneNumber = emp.PhoneNumber,
            Department = emp.Department,
            Position = emp.Position
        };
        isEditing = true;
        errors.Clear();
        showFormModal = true;
    }

    private void CloseFormModal() { if (!isSaving) showFormModal = false; }

    private bool ValidateForm()
    {
        errors.Clear();

        // Khi sửa mới cần kiểm tra mã nhân viên, khi thêm mới backend tự sinh
        if (isEditing && string.IsNullOrWhiteSpace(formModel.EmployeeCode))
            errors["EmployeeCode"] = "Mã nhân viên không được để trống";

        if (string.IsNullOrWhiteSpace(formModel.FullName))
            errors["FullName"] = "Họ tên không được để trống";

        if (string.IsNullOrWhiteSpace(formModel.Email))
            errors["Email"] = "Email không được để trống";

        // Kiểm tra định dạng số điện thoại (nếu có nhập)
        if (!string.IsNullOrWhiteSpace(formModel.PhoneNumber))
        {
            var phone = formModel.PhoneNumber.Trim();
            if (!System.Text.RegularExpressions.Regex.IsMatch(phone, @"^(0[3|5|7|8|9])[0-9]{8}$"))
                errors["PhoneNumber"] = "Số điện thoại không hợp lệ (VD: 0912345678)";
            else
            {
                var duplicate = employees.Concat(inactiveEmployees)
                    .Any(e => e.PhoneNumber == phone && e.Id != formModel.Id);
                if (duplicate)
                    errors["PhoneNumber"] = "Số điện thoại này đã được sử dụng bởi nhân viên khác.";
            }
        }

        return errors.Count == 0;
    }

    private async Task SaveEmployee()
    {
        if (!ValidateForm()) return;
        isSaving = true;
        try
        {
            if (isEditing)
            {
                var result = await ApiService.UpdateEmployeeAsync(formModel.Id, formModel);
                if (result != null && result.Id > 0)
                {
                    message = $"✅ Đã cập nhật {formModel.FullName}";
                    isSuccess = true;
                    showFormModal = false;
                    await LoadEmployeesAsync();
                }
                else
                {
                    message = "❌ Cập nhật thất bại. Vui lòng thử lại.";
                    isSuccess = false;
                }
            }
            else
            {
                var (result, errorMsg) = await ApiService.CreateEmployeeAsync(formModel);
                if (result != null && result.Id > 0)
                {
                    message = $"✅ Đã thêm {formModel.FullName}";
                    isSuccess = true;
                    showFormModal = false;
                    await LoadEmployeesAsync();
                }
                else
                {
                    message = $"❌ {errorMsg}";
                    isSuccess = false;
                }
            }
        }
        finally { isSaving = false; }
    }

    // ===== KHÔI PHỤC =====
    private void ConfirmRestore(EmployeeDto emp) { employeeToRestore = emp; showRestoreModal = true; }
    private void CloseRestoreModal() { if (!isSaving) showRestoreModal = false; }

    private async Task RestoreEmployee()
    {
        if (employeeToRestore == null) return;
        isSaving = true;
        try
        {
            var ok = await ApiService.RestoreEmployeeAsync(employeeToRestore.Id);
            if (ok)
            {
                message = $"✅ Đã khôi phục nhân viên {employeeToRestore.FullName}";
                isSuccess = true;
                showRestoreModal = false;
                employeeToRestore = null;
                activeTab = "active";
                await LoadEmployeesAsync();
            }
            else
            {
                message = "❌ Khôi phục thất bại. Vui lòng thử lại.";
                isSuccess = false;
            }
        }
        finally { isSaving = false; }
    }

 

    private void OpenAddDepartmentModal()
    {
        newDepartmentName = "";
        deptErrorMessage = "";
        showAddDeptModal = true;
    }

    private void CloseAddDepartmentModal() { showAddDeptModal = false; }

    private async Task SaveNewDepartment()
    {
        if (string.IsNullOrWhiteSpace(newDepartmentName))
        {
            deptErrorMessage = "Tên phòng ban không được để trống";
            return;
        }
        isSaving = true;
        try
        {
            var result = await ApiService.CreateDepartmentAsync(newDepartmentName.Trim());
            if (result != null)
            {
                departments.Add(result);
                formModel.Department = result.Name; // tự chọn phòng ban vừa tạo
                showAddDeptModal = false;
            }
            else
            {
                deptErrorMessage = "Phòng ban đã tồn tại hoặc có lỗi xảy ra";
            }
        }
        finally { isSaving = false; }
    }

