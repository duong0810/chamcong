@page "/Home"
@rendermode InteractiveServer
@inject ApiService ApiService

<PageTitle>Trang chủ - Chấm công</PageTitle>

<div class="home-container">
    <div class="welcome-card">
        <h1>Hệ Thống Chấm Công</h1>
        <p class="subtitle">Chấm công bằng khuôn mặt </p>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon">📊</div>
            <h3>Hôm nay</h3>
            <p class="stat-number">@todayCount</p>
            <p class="stat-label">Lượt chấm công</p>
        </div>

        <div class="stat-card">
            <div class="stat-icon">👥</div>
            <h3>Nhân viên</h3>
            <p class="stat-number">@employeeCount</p>
            <p class="stat-label">Đang hoạt động</p>
        </div>
    </div>

    <div class="quick-actions">
        <h3>🚀 Thao tác nhanh</h3>

        <div class="action-buttons">
            <a href="/attendance" class="action-card action-primary" title="Chấm công ngay">
                <span class="card-icon">📸</span>
                <span class="card-label">Chấm công ngay</span>
            </a>

            <a href="/register-face" class="action-card action-success" title="Đăng ký khuôn mặt">
                <span class="card-icon">🎭</span>
                <span class="card-label">Đăng ký khuôn mặt</span>
            </a>

            <a href="/history" class="action-card action-secondary" title="Xem lịch sử">
                <span class="card-icon">📋</span>
                <span class="card-label">Xem lịch sử</span>
            </a>
        </div>

    </div>

    @if (isLoading)
    {
        <div class="text-center mt-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Đang tải...</span>
            </div>
        </div>
    }
</div>

<style>
    :root {
        --primary: #512bd4;
        --muted: #6c757d;
        --card-bg: #ffffff;
        --accent-start: #667eea;
        --accent-end: #764ba2;
        --container-max: 840px;
    }

    .home-container {
        max-width: var(--container-max);
        margin: 1.25rem auto;
        padding: 0.9rem;
        box-sizing: border-box;
    }

    .welcome-card {
        text-align: center;
        padding: 1.1rem 1rem;
        background: linear-gradient(135deg, var(--accent-start) 0%, var(--accent-end) 100%);
        color: white;
        border-radius: 12px;
        margin-bottom: 1.25rem;
        box-shadow: 0 6px 18px rgba(25,25,40,0.08);
    }

        .welcome-card h1 {
            font-size: 1.05rem;
            margin: 0 0 0.25rem;
            font-weight: 600;
            opacity: 0.95;
        }

        .welcome-card h2 {
            font-size: 1.45rem;
            margin: 0 0 0.5rem;
            font-weight: 700;
            letter-spacing: 0.2px;
        }

    .subtitle {
        font-size: 0.98rem;
        opacity: 0.92;
        margin: 0;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 0.9rem;
        margin-bottom: 1.25rem;
    }

    .stat-card {
        background: var(--card-bg);
        padding: 0.9rem;
        border-radius: 8px;
        box-shadow: 0 4px 10px rgba(15,15,30,0.04);
        text-align: center;
        transition: transform 0.18s ease, box-shadow 0.18s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 104px;
    }

        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 25px rgba(15,15,30,0.06);
        }

    .stat-icon {
        font-size: 1.6rem;
        margin-bottom: 0.35rem;
        line-height: 1;
    }

    .stat-card h3 {
        color: var(--muted);
        font-size: 0.92rem;
        margin: 0 0 0.3rem;
        font-weight: 600;
    }

    .stat-number {
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--primary);
        margin: 0;
    }

    .stat-label {
        color: #9aa0a6;
        font-size: 0.82rem;
        margin-top: 0.45rem;
    }

    /* Quick actions: redesigned compact cards */
    .quick-actions {
        background: var(--card-bg);
        padding: 1rem;
        border-radius: 8px;
        box-shadow: 0 4px 10px rgba(15,15,30,0.04);
    }

        .quick-actions h3 {
            margin: 0 0 0.9rem;
            color: #222;
            font-size: 1rem;
            font-weight: 700;
        }

    .action-buttons {
        display: flex;
        gap: 0.8rem;
        flex-wrap: wrap;
        align-items: stretch;
    }

    .action-card {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        padding: 0.55rem 0.9rem;
        min-width: 160px;
        flex: 1 1 200px;
        border-radius: 10px;
        color: #fff;
        text-decoration: none;
        box-shadow: 0 6px 16px rgba(12,18,40,0.06);
        transition: transform .12s ease, box-shadow .12s ease;
        height: 56px;
        overflow: hidden;
        white-space: nowrap;
    }

        .action-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 14px 30px rgba(12,18,40,0.08);
        }

    .card-icon {
        display: inline-flex;
        width: 42px;
        height: 42px;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.08);
        border-radius: 8px;
        font-size: 1.25rem;
        flex: 0 0 42px;
    }

    .card-label {
        font-weight: 700;
        font-size: 0.98rem;
        color: #fff;
        display: inline-block;
        text-overflow: ellipsis;
        overflow: hidden;
    }

    /* color variants */
    .action-primary {
        background: linear-gradient(180deg,#1976d2,#1565c0);
    }

    .action-success {
        background: linear-gradient(180deg,#2e8b57,#1e7a4d);
    }

    .action-secondary {
        background: linear-gradient(180deg,#6c757d,#5b6369);
    }

    /* Responsive: stacked but compact on small screens */
    @@media (max-width: 640px) {
        .home-container

    {
        margin: 0.6rem;
        padding: 0.6rem;
    }

    .stats-grid {
        grid-template-columns: 1fr;
        gap: 0.7rem;
    }

    .stat-card {
        min-height: 88px;
        padding: 0.75rem;
        flex-direction: row;
        justify-content: flex-start;
        gap: 0.75rem;
        align-items: center;
    }

    .stat-icon {
        font-size: 1.4rem;
    }

    .stat-number {
        font-size: 1.1rem;
    }

    .action-buttons {
        flex-direction: column;
    }

    .action-card {
        width: 100%;
        height: 56px;
        flex: none;
    }

    .card-icon {
        width: 40px;
        height: 40px;
        font-size: 1.1rem;
    }

    .card-label {
        font-size: 0.98rem;
    }

    }
</style>

@code {
    private int todayCount = 0;
    private int employeeCount = 0;
    private bool hasGps = false;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Lấy thống kê
            var employees = await ApiService.GetEmployeesAsync();
            employeeCount = employees.Count;

            var todayRecords = await ApiService.GetTodayAttendanceAsync();
            todayCount = todayRecords.Count;

            // Check GPS (sẽ implement sau)
            hasGps = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Lỗi: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
}