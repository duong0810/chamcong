@page "/register-face"
@rendermode InteractiveServer
@inject ApiService ApiService
@inject AuthService AuthService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>Đăng ký khuôn mặt</PageTitle>

<div class="register-face-container">
    <h2 class="page-title">📸 Đăng Ký Khuôn Mặt</h2>
    @if (isModelsLoading)
    {
        <div class="alert alert-warning d-flex align-items-center gap-2 py-2 px-3 mb-2" role="alert">
            <div class="spinner-border spinner-border-sm text-warning" role="status"></div>
            <span>⏳ Đang tải thư viện nhận diện khuôn mặt, vui lòng chờ...</span>
        </div>
    }
    else if (isModelsReady)
    {
        <div class="alert alert-success py-2 px-3 mb-2" role="alert" style="font-size:0.88rem;">
            ✅ Thư viện nhận diện sẵn sàng
        </div>
    }


    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Đang tải...</p>
        </div>
    }
    else if (currentEmployee == null)
    {
        <div class="alert alert-warning text-center">
            <strong>⚠️</strong> Không tìm thấy thông tin nhân viên liên kết với tài khoản của bạn.
            Vui lòng liên hệ quản trị viên.
        </div>
    }
    else if (alreadyRegistered)
    {
        <div class="card">
            <div class="card-body">
                <div class="already-registered-box">
                    <div class="already-registered-icon">✅</div>
                    <h5>Bạn đã đăng ký khuôn mặt thành công!</h5>
                    <p class="text-muted mb-3">
                        Khuôn mặt của <strong>@currentEmployee.FullName</strong> đã được lưu trong hệ thống.
                        Bạn có thể sử dụng chấm công bằng khuôn mặt.
                    </p>
                    @if (!isUserRole)
                    {
                        <button class="btn btn-outline-warning" @onclick="AllowReRegister">
                            🔄 Đăng ký lại khuôn mặt
                        </button>
                    }
                    else
                    {
                        <div class="alert alert-info mt-2 mb-0 py-2 px-3" style="font-size:0.88rem;">
                            🔒 Bạn không thể đăng ký lại. Liên hệ quản trị viên nếu cần hỗ trợ.
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body">

                @if (!string.IsNullOrEmpty(message))
                {
                    <div class="alert alert-@(isSuccess ? "success" : "danger") alert-dismissible fade show mb-3" role="alert">
                        <strong>@(isSuccess ? "✅" : "❌")</strong> @message
                        <button type="button" class="btn-close" @onclick="() => message = string.Empty"></button>
                    </div>
                }

                <!-- Thông tin nhân viên hiện tại -->
                <div class="employee-info-bar mb-4">
                    <span class="employee-avatar">👤</span>
                    <div>
                        <div class="fw-semibold">@currentEmployee.FullName</div>
                        <small class="text-muted">@currentEmployee.EmployeeCode @(string.IsNullOrEmpty(currentEmployee.Department) ? "" : $"— {currentEmployee.Department}")</small>
                    </div>
                </div>

                <!-- Webcam Preview -->
                <div class="webcam-section mb-4">
                    <h5>📹 Camera</h5>

                    @if (!isCameraStarted)
                    {
                        <div class="camera-placeholder">
                            <p class="text-muted">Camera chưa bật</p>
                            <button class="btn btn-primary"
                                    @onclick="StartCameraAsync"
                                    disabled="@isProcessing">
                                📷 Bật Camera
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="video-wrapper">
                            <div class="video-container">
                                <video id="webcam" autoplay playsinline muted
                                       style="width:100%; height:auto; aspect-ratio:4/3; object-fit:cover; display:block;"></video>
                            </div>

                            <div class="face-guide-overlay">
                                <svg class="face-guide-frame" viewBox="0 0 300 400" preserveAspectRatio="xMidYMid meet">
                                    <ellipse cx="150"
                                             cy="200"
                                             rx="140"
                                             ry="180"
                                             fill="none"
                                             stroke="currentColor"
                                             stroke-width="3"
                                             stroke-dasharray="10 5"
                                             class="guide-ellipse @GetLivenessClass()" />
                                </svg>

                                @if (livenessStep > 0)
                                {
                                    <div class="liveness-progress">
                                        <div class="progress" style="height: 8px;">
                                            <div class="progress-bar @GetProgressBarClass()"
                                                 role="progressbar"
                                                 style="width: @GetProgressPercentage()%"
                                                 aria-valuenow="@livenessStep"
                                                 aria-valuemin="0"
                                                 aria-valuemax="5">
                                            </div>
                                        </div>
                                        <small class="text-white mt-1">Bước @livenessStep / 5</small>
                                    </div>
                                }

                                <div class="face-guide-text @GetLivenessClass()">
                                    @livenessMessage
                                </div>

                                <div class="face-status-icon">
                                    @if (livenessStep == 0)
                                    {
                                        <span>👤</span>
                                    }
                                    else if (livenessStep == 5)
                                    {
                                        <span>✅</span>
                                    }
                                    else if (livenessStep == 1)
                                    {
                                        <span>👁️</span>
                                    }
                                    else if (livenessStep == 2)
                                    {
                                        <span>🔍</span>
                                    }
                                    else if (livenessStep == 3)
                                    {
                                        <span>↩️</span>
                                    }
                                    else if (livenessStep == 4)
                                    {
                                        <span>🔍</span>
                                    }
                                    else
                                    {
                                        <span>⏳</span>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="camera-controls mt-3">
                            <button class="btn btn-secondary"
                                    @onclick="StopCameraAsync"
                                    disabled="@isProcessing">
                                ❌ Tắt Camera
                            </button>
                        </div>
                    }
                </div>

                <div class="alert alert-info">
                    <h6>📌 Hướng dẫn:</h6>
                    <ol class="mb-0">
                        <li>Nhấn "Bật Camera"</li>
                        <li>Làm theo hướng dẫn: Nhìn thẳng → Lại gần → Quay trái → Quay phải</li>
                        <li>Hệ thống tự chụp sau 2 giây khi hoàn thành bước 5 và tự đăng ký</li>
                        <li>Nếu đăng ký thành công, camera sẽ dừng và thông báo hiển thị</li>
                    </ol>
                </div>
            </div>
        </div>
    }
</div>

<style>
    /* Đồng bộ theo Attendance (Attendance là chuẩn) */
    .register-face-container {
        max-width: 700px;
        margin: 0 auto;
        padding: 0 0.75rem;
    }

    .page-title {
        text-align: center;
        color: #512bd4;
        margin-bottom: 1.25rem;
    }

    .card {
        border: none;
        box-shadow: 0 4px 6px rgba(0,0,0,0.06);
        border-radius: 10px;
    }

    .employee-info-bar {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: #f0f4ff;
        border: 1px solid #c7d4f5;
        border-radius: 8px;
        padding: 0.75rem 1rem;
    }

    .employee-avatar {
        font-size: 1.8rem;
